# ==========================================
# LLM Configuration
# ==========================================

# --- API Key ---
# Generic API key used for all providers (OpenAI, DeepSeek, Anthropic, local models, etc.)
LLM_API_KEY=sk-your-api-key

# --- Base URL ---
# Leave empty to use the default provider URL.
# Examples:
#   https://api.openai.com/v1              (OpenAI default)
#   https://api.anthropic.com              (Anthropic default)
#   https://api.deepseek.com               (DeepSeek — no /v1 suffix, SDK appends it)
#   http://localhost:11434/v1              (Ollama)
#   http://localhost:8000/v1               (vLLM / local)
LLM_BASE_URL=

# --- Model ---
LLM_MODEL=gpt-4o
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_MODEL=deepseek-v4-flash              (recommended)
# LLM_MODEL=deepseek-v4-pro
# LLM_MODEL=qwen2.5-coder:latest           (Ollama local)

# ==========================================
# Optional: LangSmith tracing
# ==========================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key
